# Copy to `.env` and fill in values. Never commit `.env`.

# --- Gmail (IMAP) ---
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
MAILBOX=INBOX

# --- Runtime ---
POLL_SECONDS=60
TZ=Europe/Moscow

# Where the service stores its cursor (use /data/state.json in Docker Compose).
STATE_PATH=./data/state.json

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Channel username like @mychannel, or numeric chat id.
TELEGRAM_CHAT_ID=

# Send non-image attachments as documents (default: only images via sendPhoto).
# SEND_DOCUMENT=false

# --- Optional tuning ---
# Photos use sendPhoto (Bot API limit ~10 MiB).
# MAX_PHOTO_BYTES=10485760
# Documents use sendDocument only when SEND_DOCUMENT=true (under ~50 MiB limit).
# MAX_ATTACHMENT_BYTES=51380224
# IMAP_TIMEOUT_SECONDS=120
# TELEGRAM_TIMEOUT_SECONDS=120
